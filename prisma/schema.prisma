generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Expense {
  id        String   @id @default(cuid())
  amount    Float
  category  String
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([category])
}
